nameBox.BackgroundColor3 = Color3.fromRGB(40,40,40)
nameBox.TextColor3 = Color3.new(1,1,1)

-- 🔘 BUTTON
local function btn(text, y)
    local b = Instance.new("TextButton", frame)
    b.Size = UDim2.new(1,-20,0,35)
    b.Position = UDim2.new(0,10,0,y)
    b.Text = text
    b.BackgroundColor3 = Color3.fromRGB(50,50,50)
    b.TextColor3 = Color3.new(1,1,1)
    return b
end

local start = btn("🎥 เริ่มบันทึก", 160)
local stop = btn("💾 บันทึก", 200)
local play = btn("▶️ เล่น", 240)
local load = btn("📂 โหลด", 280)

local selected = nil

-- ⏱️ UPDATE TIMER
task.spawn(function()
    while true do
        task.wait(0.2)

        if Macro.IsRecording then
            local t = math.floor(tick() - Macro.StartTime)
            timerLabel.Text = "เวลา: "..t.." วิ | กด: "..Macro.ClickCount.." ครั้ง"
        end
    end
end)

-- 🎮 LOGIC
start.MouseButton1Click:Connect(function()
    Macro:Start()
    status.Text = "🎥 กำลังบันทึก..."
end)

stop.MouseButton1Click:Connect(function()
    local name = nameBox.Text ~= "" and nameBox.Text or "macro1"
    Macro:Stop(name)
    selected = name
    status.Text = "✅ บันทึก: "..name.." ("..Macro.ClickCount.." ครั้ง)"
end)

load.MouseButton1Click:Connect(function()
    local name = nameBox.Text
    if Macro:Load(name) then
        selected = name
        status.Text = "📂 โหลดสำเร็จ: "..name
    else
        status.Text = "❌ ไม่พบ"
    end
end)

play.MouseButton1Click:Connect(function()
    if not selected then
        status.Text = "❌ ไม่มีมาโคร"
        return
    end
    Macro:Play(selected, status)
end)

