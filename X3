timerLabel.Size = UDim2.new(1,0,0,30)
timerLabel.Position = UDim2.new(0,0,0,75)
timerLabel.BackgroundColor3 = Color3.fromRGB(25,25,25)
timerLabel.TextColor3 = Color3.new(1,1,1)
