local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")
local DataStoreService = game:GetService("DataStoreService")
local HttpService = game:GetService("HttpService")

local plr = Players.LocalPlayer
local store = DataStoreService:GetDataStore("MacroDataV2")

-- =====================
-- 🔧 MACRO SYSTEM
-- =====================
local Macro = {
    Saved = {},
    Recording = {},
    IsRecording = false,
    StartTime = 0,
    ClickCount = 0
}

function Macro:Start()
    self.Recording = {}
    self.IsRecording = true
    self.StartTime = tick()
    self.ClickCount = 0
end

function Macro:Stop(name)
    self.IsRecording = false
    self.Saved[name] = self.Recording

    pcall(function()
        store:SetAsync(plr.UserId.."_"..name, HttpService:JSONEncode(self.Recording))
    end)
end

function Macro:Load(name)
    local success, data = pcall(function()
        return store:GetAsync(plr.UserId.."_"..name)
    end)

    if success and data then
        self.Saved[name] = HttpService:JSONDecode(data)
        return true
    end
    return false
end

function Macro:Record(pos)
    if not self.IsRecording then return end

    self.ClickCount += 1

    table.insert(self.Recording, {
        time = tick() - self.StartTime,
        pos = pos
    })
end

function Macro:Play(name, status)
    local data = self.Saved[name]
    if not data or #data == 0 then
        status.Text = "❌ ไม่มีข้อมูล"
        return
    end

    status.Text = "▶️ กำลังเล่น..."

    for i, v in ipairs(data) do
        local delay = v.time - (data[i-1] and data[i-1].time or 0)
        task.wait(delay)

        VIM:SendMouseButtonEvent(v.pos.X, v.pos.Y, 0, true, game, 0)
        VIM:SendMouseButtonEvent(v.pos.X, v.pos.Y, 0, false, game, 0)
    end

    status.Text = "✅ เล่นเสร็จแล้ว"
end

-- =====================
-- 📱 RECORD INPUT
-- =====================
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if input.UserInputType == Enum.UserInputType.Touch then
        Macro:Record(input.Position)
    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
        Macro:Record(UIS:GetMouseLocation())
    end
end)

-- =====================
-- 🖥️ UI
-- =====================
local gui = Instance.new("ScreenGui", plr.PlayerGui)

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 300, 0, 340)
frame.Position = UDim2.new(0.5, -150, 0.7, -170)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.Active = true

-- 🧲 TOP BAR
local topBar = Instance.new("Frame", frame)
topBar.Size = UDim2.new(1,0,0,40)
topBar.BackgroundColor3 = Color3.fromRGB(30,30,30)

local title = Instance.new("TextLabel", topBar)
title.Size = UDim2.new(1,0,1,0)
title.BackgroundTransparency = 1
title.Text = "📦 Macro System"
title.TextColor3 = Color3.new(1,1,1)

-- 🖐️ DRAG
local dragging, dragStart, startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if dragging then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- 🔔 STATUS
local status = Instance.new("TextLabel", frame)
status.Size = UDim2.new(1,0,0,35)
status.Position = UDim2.new(0,0,0,40)
status.BackgroundColor3 = Color3.fromRGB(25,25,25)
status.TextColor3 = Color3.new(1,1,1)
status.Text = "สถานะ: พร้อมใช้งาน"

-- ⏱️ TIMER
